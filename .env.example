# ── MLCopilot environment ─────────────────────────────────────────────
# Copy to .env and fill in. Docker Compose provides sane defaults for
# every infrastructure value in local development; only the AI provider
# key(s) you intend to use are required.

# ── Security (REQUIRED in production) ─────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=dev-only-change-me-in-production-0000

# ── AI providers (at least one required for AI features) ──────────────
# Anthropic Claude is the default provider.
ANTHROPIC_API_KEY=
# Optional additional providers (enable via AI_PROVIDER / fallback chain)
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
# Ollama runs locally; set the URL to enable, e.g. http://host.docker.internal:11434
OLLAMA_BASE_URL=

# Default provider id: anthropic | openai | gemini | ollama | openrouter
AI_PROVIDER=anthropic

# ── Integrations (optional) ───────────────────────────────────────────
# Fine-grained PAT with repo read scope for GitHub sync
GITHUB_TOKEN=
# MLflow tracking server for experiment import
MLFLOW_TRACKING_URI=

# ── Infrastructure (Compose defaults shown; override for prod) ────────
DATABASE_URL=postgresql+asyncpg://mlcopilot:mlcopilot@localhost:5432/mlcopilot
REDIS_URL=redis://localhost:6379/0
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mlcopilot-dev
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=mlcopilot
MINIO_SECRET_KEY=mlcopilot-dev-secret
MINIO_SECURE=false
MINIO_BUCKET=mlcopilot

# ── App ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# ── Frontend ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
