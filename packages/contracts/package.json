{
  "name": "@mlcopilot/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript API contracts generated from the MLCopilot OpenAPI specification",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "openapi-typescript ../../apps/api/openapi.json -o ./src/generated/api.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "typescript": "5.7.3"
  }
}
